#!/usr/bin/env ruby
# Run source extractor and URL tests for a given site.
#
# Usage:
#   bin/test_sources <site>   Run extractor + URL tests for <site>
#   bin/test_sources ls       List available sites

ROOT = File.expand_path("..", __dir__)
EXTRACTOR_DIR = "#{ROOT}/test/unit/source/extractor"
URL_DIR = "#{ROOT}/test/unit/source/url"

def extractor_sites
  Dir["#{EXTRACTOR_DIR}/*_extractor_test.rb"].map { |f| File.basename(f, "_extractor_test.rb") }.sort
end

def url_sites
  Dir["#{URL_DIR}/*_test.rb"].map do |f|
    name = File.basename(f, "_test.rb")
    name.delete_suffix("_url")
  end.sort
end

def all_sites
  (extractor_sites + url_sites).uniq.sort
end

def find_tests(site)
  url = Dir["#{URL_DIR}/#{site}_url_test.rb", "#{URL_DIR}/#{site}_test.rb"]
  extractor = Dir["#{EXTRACTOR_DIR}/#{site}_extractor_test.rb"]
  url + extractor
end

case ARGV[0]
when "ls"
  puts all_sites
when nil, "-h", "--help"
  puts "Usage: bin/test_sources <site>"
  puts "       bin/test_sources ls"
  exit ARGV[0] ? 0 : 1
else
  tests = find_tests(ARGV[0])

  if tests.empty?
    warn "No test files found for: #{ARGV[0]}"
    warn "Run 'bin/test_sources ls' to see available sites."
    exit 1
  end

  puts "Running the following test files:\n  - #{tests.join("\n  - ")}"

  exec "bin/rails", "test", *tests, chdir: ROOT
end
