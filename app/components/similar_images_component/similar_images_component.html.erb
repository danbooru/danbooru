<div class="similar-images-component" x-data="{ showLowSimilarity: false }">
  <h2>Similar Posts</h2>

  <p class="fineprint">
    <% if high_similarity_matches.blank? %>
      No similar posts found.
    <% end %>

    <% if low_similarity_matches.present? %>
      <%= link_to "Show #{pluralize(low_similarity_matches.length, "low similarity match")}", "javascript:void(0)", "x-on:click": "showLowSimilarity = true", "x-show": "!showLowSimilarity" %>
      <%= link_to "Hide #{pluralize(low_similarity_matches.length, "low similarity match")}", "javascript:void(0)", "x-on:click": "showLowSimilarity = false", "x-show": "showLowSimilarity", "x-cloak": true %>
    <% end %>

    <% if any_similarity_matches.any? %>
      <%= render BlacklistComponent.new(user: current_user, inline: true) %>
    <% end %>
  </p>

  <%= render(PostGalleryComponent.new(size: "180")) do |gallery| %>
    <% any_similarity_matches.each do |match| %>
      <% post = match[:post] %>

      <%= gallery.with_post(
            post: post,
            size: gallery.size,
            show_deleted: true,
            current_user: current_user,
            html: {
              "x-data": { similarity: similarity_level(match) }.to_json,
              "x-show": "similarity === 'high' || (similarity === 'low' && showLowSimilarity)",
            },
          ) do |preview| %>
        <% preview.with_footer do %>
          <div class="text-xs text-center mt-1">
            <div>
              <%= render "posts/partials/show/preview_source_footer", post: post %>
            </div>

            <div>
              <%= link_to "#{match[:score].round}% similar", iqdb_queries_path(post_id: post.id), class: "inactive-link iqdb-similarity-score" %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
