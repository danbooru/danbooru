var $div = $('div.comments-for-post[data-post-id="<%= @comment.post_id %>"] div.new-comment');
$div.find(".expand-comment-response").click();
var $editor = $div.find(".dtext-editor").get(0).editor;
var msg = <%= raw @comment.body.to_json %>;
$editor.dtext = ($editor.dtext.trim() + "\n\n" + msg).trim() + "\n\n";
